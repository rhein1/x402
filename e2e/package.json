{
  "name": "x402-e2e",
  "version": "1.0.0",
  "description": "End-to-end tests for X402 protocol",
  "packageManager": "pnpm@11.1.1",
  "main": "dist/test.js",
  "scripts": {
    "test": "tsx test.ts",
    "test:watch": "tsc --watch",
    "setup": "./setup.sh",
    "setup:legacy": "./setup.sh --legacy",
    "install:all": "pnpm install && ./setup.sh",
    "install:all:legacy": "pnpm install && ./setup.sh --legacy",
    "clean": "rm -rf dist",
    "clean:ports": "lsof -ti:4022-4060 | xargs kill -9 2>/dev/null || echo 'Ports cleared'",
    "permit2:approve": "tsx scripts/permit2-approval.ts approve",
    "permit2:revoke": "tsx scripts/permit2-approval.ts revoke",
    "swig:setup": "tsx scripts/swig-setup.ts"
  },
  "dependencies": {
    "@scure/base": "^1.2.6",
    "@solana-program/token-2022": "^0.6.1",
    "@solana/kit": "^6.1.0",
    "@swig-wallet/kit": "^2.0.0",
    "@swig-wallet/lib": "^2.0.0",
    "dotenv": "^17.0.1",
    "prompts": "^2.4.2",
    "tsx": "^4.21.0",
    "viem": "^2.48.11"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^22.13.4",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}